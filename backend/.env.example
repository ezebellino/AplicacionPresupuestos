DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
JWT_SECRET=change-me-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=120
PUBLIC_API_BASE_URL=https://your-backend.railway.app
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173,http://127.0.0.1:5173
PLATFORM_NOTIFICATION_EMAIL=admin@your-domain.com
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=smtp-password
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_USE_TLS=true
